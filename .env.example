# Archer environment — copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://archer_user:password@localhost/archer

# Telegram (only needed if notifications.provider = telegram_direct)
# If using Velocity, these are not required — Velocity reads its own .env
ARCHER_TELEGRAM_BOT_TOKEN=
ARCHER_TELEGRAM_CHAT_ID=

# GitHub (gh CLI uses its own auth — only needed for API calls not covered by gh)
# GITHUB_TOKEN=

# Velocity path (for notification delegation)
VELOCITY_DIR=/Users/johnbuccola/Developer/velo9-dev/velocity

# Repos config
REPOS_YAML=config/repos.yaml

# Admin UI
ARCHER_HOST=0.0.0.0
ARCHER_PORT=8100
ARCHER_SECRET_KEY=changeme
